#Область ToolCallingВыполнение

// Вызывает обработчики для каждого tool_call и возвращает результаты
//
// Вызывает обработчики для каждого tool_call и возвращает результаты
// Поддерживает MCP-инструменты и локальные (через обработчик)
//
Функция ВыполнитьВызовыИнструментов(ВызовыToolCalls, Обработчик, НомерИтерации)

	МассивРезультатов = Новый Массив;

	Для Каждого Вызов Из ВызовыToolCalls Цикл

		РезультатВызова = Новый Структура;
		РезультатВызова.Вставить("НомерИтерации", НомерИтерации);
		РезультатВызова.Вставить("ИмяИнструмента", Вызов.Имя);
		РезультатВызова.Вставить("Идентификатор", Вызов.Идентификатор);
		РезультатВызова.Вставить("АргументыJSON",
			ОбщегоНазначения.ЗначениеВJSON(Вызов.Аргументы));

		// Проверяем: MCP-инструмент или локальный
		Если Вызов.Свойство("MCPСервер") И ЗначениеЗаполнено(Вызов.MCPСервер) Тогда

			// === MCP-инструмент: вызов через КИИ_ConнекторMCP ===
			Попытка
				РезультатMCP = КИИ_КоннекторИИ.ВызватьИнструмент(
					Вызов.MCPСервер,
					Вызов.Имя,
					РезультатВызова.АргументыJSON);

				Если РезультатMCP.Успешно Тогда
					РезультатВызова.Вставить("Успешно", Истина);
					РезультатВызова.Вставить("Данные", РезультатMCP.ТекстРезультата);
					РезультатВызова.Вставить("ТекстОшибки", "");
				Иначе
					РезультатВызова.Вставить("Успешно", Ложь);
					РезультатВызова.Вставить("Данные", "");
					РезультатВызова.Вставить("ТекстОшибки", РезультатMCP.ТекстОшибки);
				КонецЕсли;

				РезультатВызова.Вставить("ТипВызова", "MCP");
				РезультатВызова.Вставить("MCPСервер", Вызов.MCPСервер);

			Исключение
				РезультатВызова.Вставить("Успешно", Ложь);
				РезультатВызова.Вставить("Данные", "");
				РезультатВызова.Вставить("ТекстОшибки",
					ОбработкаОшибок.ПодробноеПредставлениеОшибки(
						ИнформацияОбОшибке()));
				РезультатВызова.Вставить("ТипВызова", "MCP");
				РезультатВызова.Вставить("MCPСервер", Вызов.MCPСервер);
			КонецПопытки;

		ИначеЕсли Обработчик <> Неопределено Тогда

			// === Локальный инструмент: вызов через обработчик (v1.0.5) ===
			Попытка
				ВыполнитьОбработчикИнструмента(Обработчик, Вызов, РезультатВызова);
				РезультатВызова.Вставить("ТипВызова", "Локальный");
			Исключение
				РезультатВызова.Вставить("Успешно", Ложь);
				РезультатВызова.Вставить("ТекстОшибки",
					ОбработкаОшибок.ПодробноеПредставлениеОшибки(
						ИнформацияОбОшибке()));
				РезультатВызова.Вставить("Данные", "");
				РезультатВызова.Вставить("ТипВызова", "Локальный");
			КонецПопытки;

		Иначе

			// === Без обработчика и без MCP ===
			РезультатВызова.Вставить("Успешно", Ложь);
			РезультатВызова.Вставить("ТекстОшибки",
				НСтр("ru = 'Обработчик инструментов не указан'"));
			РезультатВызова.Вставить("Данные", "");
			РезультатВызова.Вставить("ТипВызова", "");

		КонецЕсли;

		МассивРезультатов.Добавить(РезультатВызова);

	КонецЦикла;

	Возврат МассивРезультатов;

КонецФункции

// Вызывает обработчик инструмента
// В MCP-first подходе локальные обработчики не используются.
// Все инструменты вызываются через MCP-серверы.
//
Процедура ВыполнитьОбработчикИнструмента(Обработчик, Вызов, РезультатВызова)

	РезультатВызова.Вставить("Успешно", Ложь);
	РезультатВызова.Вставить("Данные",
		СтрШаблон(НСтр("ru = 'Локальные обработчики не поддерживаются. Используйте MCP-инструменты.'")));
	РезультатВызова.Вставить("ТекстОшибки",
		СтрШаблон(НСтр("ru = 'Инструмент %1: локальный обработчик не задан'"), Вызов.Имя));

КонецПроцедуры

#Область ToolCallingБезопасность

// Проверяет корректность имени инструмента
// Имя должно содержать только латинские буквы, цифры, подчеркивания и дефисы,
// начинаться с буквы и иметь длину от 1 до 100 символов
//
Функция ПроверитьИмяИнструмента(Имя)

	Если Не ЗначениеЗаполнено(Имя) Тогда
		Возврат Ложь;
	КонецЕсли;

	Если СтрДлина(Имя) > 100 Тогда
		Возврат Ложь;
	КонецЕсли;

	Буквы = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ";
	ДопустимыеСимволы = Буквы + "0123456789_-";

	ПервыйСимвол = Лев(Имя, 1);
	Если СтрНайти(Буквы, ПервыйСимвол) = 0 Тогда
		Возврат Ложь;
	КонецЕсли;

	Для Индекс = 2 По СтрДлина(Имя) Цикл
		Символ = Сред(Имя, Индекс, 1);
		Если СтрНайти(ДопустимыеСимволы, Символ) = 0 Тогда
			Возврат Ложь;
		КонецЕсли;
	КонецЦикла;

	Возврат Истина;

КонецФункции

#КонецОбласти

