// Добавляет инструменты в тело запроса Anthropic
//
Процедура ДобавитьИнструментыВТелоЗапросаAnthropic(ТелоЗапроса, ИнструментыДляЗапроса)

	Если ИнструментыДляЗапроса <> Неопределено
		И ИнструментыДляЗапроса.Количество() > 0 Тогда
		ТелоЗапроса.Вставить("tools", ИнструментыДляЗапроса);
		ToolChoice = Новый Структура;
		ToolChoice.Вставить("type", "auto");
		ТелоЗапроса.Вставить("tool_choice", ToolChoice);
	КонецЕсли;

КонецПроцедуры

// Извлекает tool_use из ответа Anthropic
//
Функция ИзвлечьВызовыИнструментовAnthropic(ОтветJSON)

	Результат = Новый Массив;

	Если Не ОтветJSON.Свойство("content") Тогда
		Возврат Результат;
	КонецЕсли;

	Для Каждого Элемент Из ОтветJSON.content Цикл
		Если ЭтоСтруктура(Элемент)
			И Элемент.Свойство("type")
			И Элемент.type = "tool_use" Тогда
			Вызов = Новый Структура;
			Вызов.Вставить("Идентификатор", Элемент.id);
			Вызов.Вставить("Имя", Элемент.name);
			Вызов.Вставить("Аргументы", Элемент.input);
			Результат.Добавить(Вызов);
		КонецЕсли;
	КонецЦикла;

	Возврат Результат;

КонецФункции

// Формирует сообщения с результатами инструментов для Anthropic
//
Функция СформироватьСообщенияРезультатовИнструментовAnthropic(
	ОтветJSON, РезультатыВызовов)

	МассивСообщений = Новый Массив;

	// 1. Сообщение assistant -- исходное сообщение из ответа (включает text и tool_use)
	СообщениеAssistant = Новый Структура;
	СообщениеAssistant.Вставить("role", "assistant");
	СообщениеAssistant.Вставить("content", ОтветJSON.content);
	МассивСообщений.Добавить(СообщениеAssistant);

	// 2. Сообщение user -- tool_result
	МассивToolResults = Новый Массив;

	Для Каждого РезультатВызова Из РезультатыВызовов Цикл

		ToolResult = Новый Структура;
		ToolResult.Вставить("type", "tool_result");
		ToolResult.Вставить("tool_use_id", РезультатВызова.Идентификатор);

		Если РезультатВызова.Успешно Тогда
			ToolResult.Вставить("content",
				ОбщегоНазначения.ЗначениеВJSON(
					РезультатВызова.Данные));
		Иначе
			ToolResult.Вставить("content", РезультатВызова.ТекстОшибки);
			ToolResult.Вставить("is_error", Истина);
		КонецЕсли;

		МассивToolResults.Добавить(ToolResult);
	КонецЦикла;

	СообщениеUser = Новый Структура;
	СообщениеUser.Вставить("role", "user");
	СообщениеUser.Вставить("content", МассивToolResults);
	МассивСообщений.Добавить(СообщениеUser);

	Возврат МассивСообщений;

КонецФункции

