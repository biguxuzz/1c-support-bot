#КонецОбласти

Функция РасшифровкаКодаОшибки(КодHTTP, СтрОшибкаJSON = "")

	КодAPI = ИзвлечьКодОшибкиAPI(СтрОшибкаJSON);
	ТекстОшибки = ПолучитьОписаниеHTTPОшибки(КодHTTP);

	Если Не ПустаяСтрока(КодAPI) Тогда
		ОписаниеAPIОшибки = ПолучитьОписаниеAPIОшибки(КодAPI);

		Если ОписаниеAPIОшибки <> Неопределено Тогда
			ТекстОшибки = СтрШаблон("%1, %2", ТекстОшибки, ОписаниеAPIОшибки);
		КонецЕсли;
	КонецЕсли;

	Возврат ТекстОшибки;

КонецФункции

Функция ИзвлечьКодОшибкиAPI(СтрОшибкаJSON)

	Если ПустаяСтрока(СтрОшибкаJSON) Тогда
		Возврат "";
	КонецЕсли;

	Попытка
		СтруктураОшибки = ОбщегоНазначения.JSONВЗначение(СтрОшибкаJSON);

		Если ТипЗнч(СтруктураОшибки) = Тип("Структура") 
			И СтруктураОшибки.Свойство("code") Тогда
			Возврат СтруктураОшибки.code;
		КонецЕсли;
	Исключение
		ЗаписьЖурналаРегистрации(
			НСтр("ru = 'КИИ.HTTPОшибка'", ОбщегоНазначения.КодОсновногоЯзыка()),
			УровеньЖурналаРегистрации.Ошибка,
			,
			,
			ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
	КонецПопытки;

	Возврат "";

КонецФункции

Функция ПолучитьОписаниеHTTPОшибки(КодHTTP)

	КартаHTTP = Новый Соответствие;
	КартаHTTP.Вставить(400, НСтр("ru = 'Неверный запрос (400)'"));
	КартаHTTP.Вставить(401, НСтр("ru = 'Ключ API отсутствует или недействителен (401)'"));
	КартаHTTP.Вставить(403, НСтр("ru = 'Доступ запрещен (403)'"));
	КартаHTTP.Вставить(404, НСтр("ru = 'Ресурс не найден (404)'"));
	КартаHTTP.Вставить(429, НСтр("ru = 'Превышен лимит запросов или квота (429)'"));
	КартаHTTP.Вставить(500, НСтр("ru = 'Внутренняя ошибка сервера (500)'"));
	КартаHTTP.Вставить(502, НСтр("ru = 'Bad Gateway (502)'"));
	КартаHTTP.Вставить(503, НСтр("ru = 'Сервис временно недоступен (503)'"));
	КартаHTTP.Вставить(504, НСтр("ru = 'Gateway Timeout (504)'"));

	ОписаниеКодаОшибки = КартаHTTP.Получить(КодHTTP);

	Если ОписаниеКодаОшибки = Неопределено Тогда
		Возврат СтрШаблон(НСтр("ru = 'Неизвестная ошибка: %1'"), КодHTTP);
	КонецЕсли;

	Возврат ОписаниеКодаОшибки;

КонецФункции

Функция ПолучитьОписаниеAPIОшибки(КодAPI)

	КартаAPI = Новый Соответствие;
	КартаAPI.Вставить("invalid_api_key",         НСтр("ru = 'Ключ API недействителен или отозван'"));
	КартаAPI.Вставить("insufficient_quota",      НСтр("ru = 'Недостаточная квота для операции'"));
	КартаAPI.Вставить("context_length_exceeded", НСтр("ru = 'Превышена максимальная длина контекста'"));
	КартаAPI.Вставить("rate_limit_reached",      НСтр("ru = 'Достигнут предел скорости запросов'"));
	КартаAPI.Вставить("model_not_found",         НСтр("ru = 'Запрошенная модель не найдена'"));
	КартаAPI.Вставить("server_overloaded",       НСтр("ru = 'Сервер перегружен, попробуйте позже'"));
	КартаAPI.Вставить("timeout",                 НСтр("ru = 'Превышено время ожидания операции'"));

	Возврат КартаAPI.Получить(КодAPI);

КонецФункции


#Область ToolCalling

// Основной цикл tool calling: отправляет запросы с инструментами,
// обрабатывает вызовы инструментов и повторяет до получения текстового ответа
//
// Параметры:
//  Модель - СправочникСсылка.КИИ_МоделиИИ
//  СтруктураПромпта - Структура - подготовленный промпт
//  Инструменты - Массив из Структура - определения инструментов
//  Обработчик - ОписаниеОповещения, Неопределено - обработчик вызова инструмента
//  МаксимумИтераций - Число - макс. количество циклов tool calling
//  Результат - Структура - заполняемый результат
//  ДатаНачала - Дата - дата начала запроса
//
Процедура ВыполнитьЗапросСToolCalling(Модель, СтруктураПромпта, Инструменты,
	Обработчик, МаксимумИтераций, Результат, ДатаНачала)

	Параметры = ПараметрыМодели(Модель);
	КлючAPI = ПолучитьКлючAPI(Модель, Параметры);

	// Подготовить инструменты в формате провайдера
	ИнструментыДляЗапроса = Неопределено;
	Если ПоддерживаетToolCalling(Параметры) И Инструменты <> Неопределено Тогда
		ИнструментыДляЗапроса = СформироватьИнструментыПоПровайдеру(Параметры, Инструменты);
	КонецЕсли;

	// Формируем сопоставление: Имя инструмента -> MCPСервер
	// для маршрутизации вызовов в ВыполнитьВызовыИнструментов()
	СоответствиеИнструментов = Новый Соответствие;
	Если Инструменты <> Неопределено Тогда
		Для Каждого Инструмент Из Инструменты Цикл
			Если Инструмент.Свойство("MCPСервер") И ЗначениеЗаполнено(Инструмент.MCPСервер) Тогда
				СоответствиеИнструментов.Вставить(Инструмент.Имя, Инструмент.MCPСервер);
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;

	ВызовыИнструментов = Новый Массив;
	НомерИтерации = 0;

	Пока Истина Цикл

		НомерИтерации = НомерИтерации + 1;
		Если НомерИтерации > МаксимумИтераций Тогда
			Результат.ЭтоОшибка = Истина;
			Результат.ТекстОшибки = СтрШаблон(
				НСтр("ru = 'Превышен лимит итераций tool calling (%1)'"),
				МаксимумИтераций);
			Прервать;
		КонецЕсли;

		// Сформировать и отправить запрос
		Соединение = СоздатьHTTPСоединение(Параметры);
		Запрос = СформироватьHTTPЗапросСИнструментами(
			Параметры, КлючAPI, СтруктураПромпта, ИнструментыДляЗапроса);

		ОтветHTTP = ОтправитьЗапросСПовторомПриОшибке401(
			Соединение, Запрос, Модель, Параметры, КлючAPI);

		Если ОтветHTTP.КодСостояния <> 200 Тогда
			ОбработатьОшибкуОтвета(ОтветHTTP, Результат);
			Возврат;
		КонецЕсли;

		ТелоОтвета = ОтветHTTP.ПолучитьТелоКакСтроку();
		ОтветJSON = ОбщегоНазначения.JSONВЗначение(ТелоОтвета, , Ложь);

		// Проверить наличие tool_calls
		ВызовыToolCalls = ИзвлечьВызовыИнструментовИзОтвета(Параметры, ОтветJSON);

		// Добавляем MCP-контекст к вызовам инструментов
		Для Каждого Вызов Из ВызовыToolCalls Цикл
			MCPСервер = СоответствиеИнструментов.Получить(Вызов.Имя);
			Если MCPСервер <> Неопределено Тогда
				Вызов.Вставить("MCPСервер", MCPСервер);
			КонецЕсли;
		КонецЦикла;

		Если ВызовыToolCalls.Количество() = 0 Тогда
			// Обычный текстовый ответ -- завершаем цикл
			ОбработатьОтветПоТипуМодели(Параметры, ОтветJSON, Результат);
			Прервать;
		КонецЕсли;

		// Обработка tool calls
		РезультатыВызовов = ВыполнитьВызовыИнструментов(
			ВызовыToolCalls, Обработчик, НомерИтерации);

		Для Каждого РезультатВызова Из РезультатыВызовов Цикл
			ВызовыИнструментов.Добавить(РезультатВызова);
		КонецЦикла;

		// Добавить сообщения с результатами инструментов в историю
		ДобавитьСообщенияИнструментовВИсторию(
			СтруктураПромпта, Параметры, ОтветJSON, ВызовыToolCalls, РезультатыВызовов);

		// Обновить токены из промежуточного ответа
		ОбработатьМетаданныеОтвета(Параметры, ОтветJSON, Результат);

	КонецЦикла;

	// Заполнить расширенные поля результата
	Результат.БылиВызовыИнструментов = ВызовыИнструментов.Количество() > 0;
	Результат.КоличествоИтераций = НомерИтерации;
	Результат.ВызовыИнструментов = ВызовыИнструментов;

	Результат.ВремяОтветаСекунд = (ТекущаяДатаСеанса() - ДатаНачала);
	Результат.Модель = Модель;
	Результат.ДатаЗапроса = ДатаНачала;

КонецПроцедуры

// Формирует HTTP-запрос с инструментами для tool calling
//
Функция СформироватьHTTPЗапросСИнструментами(Параметры, КлючAPI, СтруктураПромпта,
	ИнструментыДляЗапроса)

	Запрос = Новый HTTPЗапрос(Параметры.АдресЗапроса);

	Заголовки = Новый Соответствие;
	ТелоЗапроса = Новый Структура;

	СформироватьЗаголовкиИТелоПоМодели(Параметры, КлючAPI, СтруктураПромпта, Заголовки, ТелоЗапроса);

	// Добавить инструменты в тело запроса
	Если ИнструментыДляЗапроса <> Неопределено Тогда
		ДобавитьИнструментыВТелоЗапросаПоПровайдеру(Параметры, ТелоЗапроса, ИнструментыДляЗапроса);
	КонецЕсли;

	Для Каждого Заголовок Из Заголовки Цикл
		Запрос.Заголовки.Вставить(Заголовок.Ключ, Заголовок.Значение);
	КонецЦикла;

	ТелоJSON = ОбщегоНазначения.ЗначениеВJSON(ТелоЗапроса);
	Запрос.УстановитьТелоИзСтроки(ТелоJSON, КодировкаТекста.UTF8);

	Возврат Запрос;

КонецФункции

// Добавляет сообщения с результатами инструментов в историю сообщений
//
Процедура ДобавитьСообщенияИнструментовВИсторию(СтруктураПромпта, Параметры,
	ОтветJSON, ВызовыToolCalls, РезультатыВызовов)

	ТипФормата = Параметры.ТипФорматаAPI;

	Если ТипФормата = Перечисления.КИИ_ТипыФорматовAPI.OpenAI_Compatible Тогда
		Сообщения = СформироватьСообщенияРезультатовИнструментовOpenAI(
			ВызовыToolCalls, РезультатыВызовов);
	ИначеЕсли ТипФормата = Перечисления.КИИ_ТипыФорматовAPI.Anthropic Тогда
		Сообщения = СформироватьСообщенияРезультатовИнструментовAnthropic(
			ОтветJSON, РезультатыВызовов);
	ИначеЕсли ТипФормата = Перечисления.КИИ_ТипыФорматовAPI.Google Тогда
		Сообщения = СформироватьСообщенияРезультатовИнструментовGoogle(
			ВызовыToolCalls, РезультатыВызовов);
	ИначеЕсли ТипФормата = Перечисления.КИИ_ТипыФорматовAPI.Yandex Тогда
		Сообщения = СформироватьСообщенияРезультатовИнструментовOpenAI(
			ВызовыToolCalls, РезультатыВызовов);
	Иначе
		Возврат;
	КонецЕсли;

	Для Каждого Сообщение Из Сообщения Цикл
		СтруктураПромпта.ИсторияСообщений.Добавить(Сообщение);
	КонецЦикла;

КонецПроцедуры

// Обрабатывает метаданные промежуточного ответа (токены)
//
Процедура ОбработатьМетаданныеОтвета(Параметры, ОтветJSON, Результат)

	Если ЕстьОшибкаВОтветеAPI(ОтветJSON, Результат) Тогда
		Возврат;
	КонецЕсли;

	ТипФормата = Параметры.ТипФорматаAPI;

	Если ТипФормата = Перечисления.КИИ_ТипыФорматовAPI.OpenAI_Compatible Тогда
		ИзвлечьТокеныOpenAI(ОтветJSON, Результат);
	ИначеЕсли ТипФормата = Перечисления.КИИ_ТипыФорматовAPI.Anthropic Тогда
		ИзвлечьТокеныAnthropic(ОтветJSON, Результат);
	ИначеЕсли ТипФормата = Перечисления.КИИ_ТипыФорматовAPI.Google Тогда
		ИзвлечьТокеныGoogle(ОтветJSON, Результат);
	ИначеЕсли ТипФормата = Перечисления.КИИ_ТипыФорматовAPI.Yandex Тогда
		ИзвлечьТокеныYandex(ОтветJSON, Результат);
	КонецЕсли;

КонецПроцедуры

