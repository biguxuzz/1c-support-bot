// Извлекает functionCall из ответа Google
//
Функция ИзвлечьВызовыИнструментовGoogle(ОтветJSON)

	Результат = Новый Массив;

	Если Не ОтветJSON.Свойство("candidates") Тогда
		Возврат Результат;
	КонецЕсли;

	Кандидат = ОтветJSON.candidates[0];
	Если Не ЭтоСтруктура(Кандидат) Или Не Кандидат.Свойство("content") Тогда
		Возврат Результат;
	КонецЕсли;

	Если Не ЭтоСтруктура(Кандидат.content)
		Или Не Кандидат.content.Свойство("parts") Тогда
		Возврат Результат;
	КонецЕсли;

	Для Каждого Часть Из Кандидат.content.parts Цикл
		Если ЭтоСтруктура(Часть) И Часть.Свойство("functionCall") Тогда
			Вызов = Новый Структура;
			Вызов.Вставить("Идентификатор", ""); // Google не использует ID
			Вызов.Вставить("Имя", Часть.functionCall.name);
			Вызов.Вставить("Аргументы", Часть.functionCall.args);
			Результат.Добавить(Вызов);
		КонецЕсли;
	КонецЦикла;

	Возврат Результат;

КонецФункции

// Формирует сообщения с результатами инструментов для Google
//
Функция СформироватьСообщенияРезультатовИнструментовGoogle(
	ToolCallsИзОтвета, РезультатыВызовов)

	МассивСообщений = Новый Массив;

	// 1. Сообщение model (assistant) с functionCall
	МассивParts = Новый Массив;
	Для Каждого ToolCall Из ToolCallsИзОтвета Цикл
		Part = Новый Структура;
		FunctionCall = Новый Структура;
		FunctionCall.Вставить("name", ToolCall.Имя);
		FunctionCall.Вставить("args", ToolCall.Аргументы);
		Part.Вставить("functionCall", FunctionCall);
		МассивParts.Добавить(Part);
	КонецЦикла;

	СообщениеModel = Новый Структура;
	СообщениеModel.Вставить("role", "model");
	СообщениеModel.Вставить("parts", МассивParts);
	МассивСообщений.Добавить(СообщениеModel);

	// 2. Сообщение user с functionResponse
	МассивResponses = Новый Массив;
	Для Индекс = 0 По РезультатыВызовов.ВГраница() Цикл
		РезультатВызова = РезультатыВызовов[Индекс];
		ToolCall = ToolCallsИзОтвета[Индекс];

		ResponsePart = Новый Структура;
		FunctionResponse = Новый Структура;
		FunctionResponse.Вставить("name", ToolCall.Имя);
		Если РезультатВызова.Успешно Тогда
			FunctionResponse.Вставить("response", РезультатВызова.Данные);
		Иначе
			FunctionResponse.Вставить("response",
				СтрШаблон("{""error"": ""%1""}", РезультатВызова.ТекстОшибки));
		КонецЕсли;
		ResponsePart.Вставить("functionResponse", FunctionResponse);
		МассивResponses.Добавить(ResponsePart);
	КонецЦикла;

	СообщениеUser = Новый Структура;
	СообщениеUser.Вставить("role", "user");
	СообщениеUser.Вставить("parts", МассивResponses);
	МассивСообщений.Добавить(СообщениеUser);

	Возврат МассивСообщений;

