// Формирует массив tools в формате Anthropic
//
Функция СформироватьИнструментыAnthropic(Инструменты)

	МассивTools = Новый Массив;

	Для Каждого Инструмент Из Инструменты Цикл

		Если Не ПроверитьИмяИнструмента(Инструмент.Имя) Тогда
			Продолжить;
		КонецЕсли;

		ToolDef = Новый Структура;
		ToolDef.Вставить("name", Инструмент.Имя);
		ToolDef.Вставить("description", Инструмент.Описание);

		// Anthropic использует "input_schema" вместо "parameters"
		Если Инструмент.Свойство("Параметры") Тогда
			Попытка
				Если ТипЗнч(Инструмент.Параметры) = Тип("Строка") Тогда
					ToolDef.Вставить("input_schema",
						ОбщегоНазначения.JSONВЗначение(
							Инструмент.Параметры, , Ложь));
				Иначе
					ToolDef.Вставить("input_schema", Инструмент.Параметры);
				КонецЕсли;
			Исключение
				ToolDef.Вставить("input_schema", Новый Структура("type", "object"));
			КонецПопытки;
		Иначе
			ToolDef.Вставить("input_schema", Новый Структура("type", "object"));
		КонецЕсли;

		МассивTools.Добавить(ToolDef);

	КонецЦикла;

	Возврат МассивTools;

