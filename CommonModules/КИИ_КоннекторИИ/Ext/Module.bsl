		Возврат;
	КонецЕсли;

	Если Использование.completion_tokens_details.Свойство("cached_tokens") Тогда
		Результат.ВыходныеТокеныВКеше = Использование.completion_tokens_details.cached_tokens;
	КонецЕсли;

КонецПроцедуры

