	Если Использование.Свойство("completionTokens") Тогда
		Результат.ВыходныеТокены = Использование.completionTokens;
	КонецЕсли;

	Если Использование.Свойство("totalTokens") Тогда
		Результат.ВсегоТокенов = Использование.totalTokens;
	КонецЕсли;

