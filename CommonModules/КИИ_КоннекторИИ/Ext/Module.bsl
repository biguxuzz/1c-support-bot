#Область ПрограммныйИнтерфейс

// Выполняет синхронный запрос к модели ИИ
//
// Параметры:
//  Модель - СправочникСсылка.КИИ_МоделиИИ - модель для запроса
//  Промпт - Строка, Структура - запрос к модели:
//    * Строка - Строка - простой текст запроса
//    * СистемныйПромпт - Строка - системное сообщение
//    * ПользовательскийПромпт - Строка - запрос пользователя
//    * ИсторияСообщений - Массив - предыдущие ответы (необязательно)
//
// Возвращаемое значение:
//  Структура - результат запроса со свойствами:
//    * ЭтоОшибка - Булево - признак ошибки выполнения запроса
//    * ТекстОшибки - Строка - текст ошибки (если ЭтоОшибка = Истина)
//    * ТекстОтвета - Строка - текст ответа от модели ИИ
//    * ВходныеТокены - Число - количество токенов во входном запросе
//    * ВыходныеТокены - Число - количество токенов в ответе
//    * ВсегоТокенов - Число - общее количество использованных токенов
//    * ВыходныеТокеныВКеше - Число - количество закэшированных токенов
//    * ВремяОтветаСекунд - Число - время выполнения запроса в секундах
//    * СтоимостьОтвета - Число - стоимость запроса (если поддерживается провайдером)
//    * Модель - СправочникСсылка.КИИ_МоделиИИ, Неопределено - использованная модель
//    * МодельОтвета - Строка - фактическое имя модели из ответа
//    * ДатаЗапроса - Дата, Неопределено - дата и время начала запроса
//    * ДатаСоздания - Дата, Неопределено - дата создания ответа по данным провайдера
//    * ПричинаЗавершения - Строка - причина завершения генерации (stop, length и т.д.)
//    * Идентификатор - Строка - уникальный идентификатор записи лога
//    * УниверсальнаяДатаВМиллисекундах - Число - универсальное время в миллисекундах
//    * IDЗапроса - Строка - идентификатор запроса от провайдера
//    * ТипОбъекта - Строка - тип объекта ответа
//    * ТарифСервиса - Строка - использованный тариф сервиса
//    * ХэшМодели - Строка - отпечаток версии модели
//
// Пример:
//  Модель = Справочники.КИИ_МоделиИИ.НайтиПоНаименованию("GPT-4o");
//  Ответ = КИИ_КоннекторИИ.ЗапросКМодели(Модель, "Привет!");
//  
//  Если Не Ответ.ЭтоОшибка Тогда
//      Сообщить(Ответ.ТекстОтвета);
//  КонецЕсли;
//
Функция ЗапросКМодели(Модель, Промпт) Экспорт

	Результат = НовыйПараметрыОтветаИИ();
	ДатаНачала = ТекущаяДатаСеанса();

	Если Не ЗначениеЗаполнено(Модель) Тогда
		Результат.ЭтоОшибка = Истина;
		Результат.ТекстОшибки = НСтр("ru = 'Не заполнена модель ИИ'");
		Возврат Результат;
	КонецЕсли;

	Попытка

		ВыполнитьЗапросКМодели(Модель, Промпт, Результат, ДатаНачала);

	Исключение

		Результат.ЭтоОшибка = Истина;
		Результат.ТекстОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());

	КонецПопытки;

	СтруктураПромпта = ПодготовитьПромпт(Промпт);
	ЗаписатьЛогИИ(Модель, СтруктураПромпта, Результат);

	Возврат Результат;

КонецФункции

// Выполняет асинхронный запрос к модели ИИ через длительные операции
//
// Параметры:
//  Модель - СправочникСсылка.КИИ_МоделиИИ
//  Промпт - Строка, Структура - см. ЗапросКМодели
//
// Возвращаемое значение:
//  См. ДлительныеОперации.ВыполнитьВФоне
//
Функция ЗапросКМоделиВФоне(Модель, Промпт) Экспорт
	
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияВФоне(Новый УникальныйИдентификатор);
	ПараметрыВыполнения.НаименованиеФоновогоЗадания = НСтр("ru = 'Запрос к модели ИИ'");
	ПараметрыВыполнения.ЗапуститьВФоне = Истина;
	
	ПараметрыМетода = Новый Структура;
	ПараметрыМетода.Вставить("Модель", Модель);
	ПараметрыМетода.Вставить("Промпт", Промпт);
	
	Возврат ДлительныеОперации.ВыполнитьВФоне(
		"КИИ_КоннекторИИ.ЗапросКМоделиФоновоеЗадание",
		ПараметрыМетода,
		ПараметрыВыполнения);
	
КонецФункции

// Выполняет синхронный запрос к модели ИИ с поддержкой tool calling
//
// Параметры:
//  Модель - СправочникСсылка.КИИ_МоделиИИ - модель для запроса
//  Промпт - Строка, Структура - запрос к модели (см. ЗапросКМодели)
//  Инструменты - Массив из Структура - определения инструментов:
//    * Имя - Строка - уникальное имя функции
//    * Описание - Строка - описание функции для модели
//    * Параметры - Структура, Строка - JSON Schema параметров (объект или JSON-строка)
//  Обработчик - ОписаниеОповещения, Неопределено - обработчик вызова инструмента:
//    - Если ОписаниеОповещения: вызывается при каждом tool_call
//    - Если Неопределено: tool calls возвращаются в свойстве ВызовыИнструментов результата
//  ПараметрыВыполнения - Структура, Неопределено - дополнительные параметры:
//    * МаксимумИтераций - Число - макс. количество циклов tool calling (по умолчанию: 10)
//
// Возвращаемое значение:
//  Структура - результат запроса (расширенный, включает поля tool calling)
//
// Пример:
//  Инструменты = Новый Массив;
//  Поиск = Новый Структура;
//  Поиск.Вставить("Имя", "search_documents");
//  Поиск.Вставить("Описание", "Поиск документов по запросу");
//  Поиск.Вставить("Параметры", "{""type"":""object"",""properties"":{""query"":{""type"":""string""}}}");
//  Инструменты.Добавить(Поиск);
//  Результат = КИИ_КоннекторИИ.ЗапросКМоделиСИнструментами(Модель, "Найди договоры", Инструменты);
//
Функция ЗапросКМоделиСИнструментами(Модель, Промпт, Инструменты,
	Обработчик = Неопределено, ПараметрыВыполнения = Неопределено) Экспорт

	Результат = НовыйПараметрыОтветаИИ();
	ДатаНачала = ТекущаяДатаСеанса();

	Если Не ЗначениеЗаполнено(Модель) Тогда
		Результат.ЭтоОшибка = Истина;
		Результат.ТекстОшибки = НСтр("ru = 'Не заполнена модель ИИ'");
		Возврат Результат;
	КонецЕсли;

	Попытка
		СтруктураПромпта = ПодготовитьПромпт(Промпт);

		// Параметры выполнения по умолчанию
		МаксимумИтераций = 10;
		Если ПараметрыВыполнения <> Неопределено Тогда
			Если ПараметрыВыполнения.Свойство("МаксимумИтераций") Тогда
				МаксимумИтераций = ПараметрыВыполнения.МаксимумИтераций;
			КонецЕсли;
		КонецЕсли;

		// Если инструментов нет или они пустые -- обычный запрос
		Если Инструменты = Неопределено ИЛИ Инструменты.Количество() = 0 Тогда
			ВыполнитьЗапросКМодели(Модель, Промпт, Результат, ДатаНачала);
		Иначе
			ВыполнитьЗапросСToolCalling(Модель, СтруктураПромпта,
				Инструменты, Обработчик, МаксимумИтераций,
				Результат, ДатаНачала);
		КонецЕсли;

	Исключение
		Результат.ЭтоОшибка = Истина;
		Результат.ТекстОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(
			ИнформацияОбОшибке());
	КонецПопытки;

	СтруктураПромпта = ПодготовитьПромпт(Промпт);
	ЗаписатьЛогИИ(Модель, СтруктураПромпта, Результат);

	Возврат Результат;

КонецФункции

// Выполняет асинхронный запрос к модели ИИ с tool calling через длительные операции
//
// Параметры:
//  Модель - СправочникСсылка.КИИ_МоделиИИ
//  Промпт - Строка, Структура - см. ЗапросКМодели
//  Инструменты - Массив из Структура - определения инструментов (см. ЗапросКМоделиСИнструментами)
//  ИмяОбработчикаИнструмента - Строка - имя экспортной процедуры/функции
//    в общем модуле, которая будет вызвана для выполнения инструмента.
//    Сигнатура: Процедура ИмяОбработчикаИнструмента(ИмяИнструмента, Аргументы, Результат)
//    где:
//      ИмяИнструмента - Строка - имя вызванного инструмента
//      Аргументы - Структура - распарсенные аргументы JSON
//      Результат - Структура - заполняется обработчиком:
//        * Успешно - Булево
//        * Данные - Строка, Структура - результат выполнения
//        * ТекстОшибки - Строка - описание ошибки (при Успешно = Ложь)
//
// Возвращаемое значение:
//  См. ДлительныеОперации.ВыполнитьВФоне
//
Функция ЗапросКМоделиСИнструментамиВФоне(Модель, Промпт, Инструменты,
	ИмяОбработчикаИнструмента = "") Экспорт

	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияВФоне(Новый УникальныйИдентификатор);
	ПараметрыВыполнения.НаименованиеФоновогоЗадания = НСтр("ru = 'Запрос к модели ИИ с инструментами'");
	ПараметрыВыполнения.ЗапуститьВФоне = Истина;

	ПараметрыМетода = Новый Структура;
	ПараметрыМетода.Вставить("Модель", Модель);
	ПараметрыМетода.Вставить("Промпт", Промпт);
	ПараметрыМетода.Вставить("Инструменты", Инструменты);
	ПараметрыМетода.Вставить("ИмяОбработчикаИнструмента", ИмяОбработчикаИнструмента);

	Возврат ДлительныеОперации.ВыполнитьВФоне(
		"КИИ_КоннекторИИ.ЗапросКМоделиСИнструментамиФоновоеЗадание",
		ПараметрыМетода,
		ПараметрыВыполнения);

КонецФункции

// Возвращает массив инструментов, настроенных для эксперта
// Поддерживает как локальные (ручные), так и MCP-инструменты
//
// Параметры:
//  Эксперт - СправочникСсылка.КИИ_ЭкспертыИИ
//
// Возвращаемое значение:
//  Массив из Структура - определения инструментов (только включенные):
//    * Имя - Строка
//    * Описание - Строка
//    * Параметры - Строка (JSON Schema)
//    * MCPСервер - СправочникСсылка.КИИ_MCPСерверы, Неопределено
//    * ИнструментСсылка - СправочникСсылка.КИИ_ИнструментыИИ, Неопределено
//
Функция ИнструментыЭксперта(Эксперт) Экспорт

	Результат = Новый Массив;

	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	КИИ_ЭкспертыИИИнструменты.MCP КАК MCP,
		|	КИИ_ЭкспертыИИИнструменты.Инструмент КАК Инструмент,
		|	КИИ_ЭкспертыИИИнструменты.Использовать КАК Использовать,
		|	КИИ_ИнструментыИИ.Наименование КАК Имя,
		|	КИИ_ИнструментыИИ.Описание КАК Описание,
		|	КИИ_ИнструментыИИ.ПараметрыJSON КАК ПараметрыJSON
		|ИЗ
		|	Справочник.КИИ_ЭкспертыИИ.Инструменты КАК КИИ_ЭкспертыИИИнструменты
		|	ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КИИ_ИнструментыИИ КАК КИИ_ИнструментыИИ
		|		ПО КИИ_ЭкспертыИИИнструменты.Инструмент = КИИ_ИнструментыИИ.Ссылка
		|ГДЕ
		|	КИИ_ЭкспертыИИИнструменты.Ссылка = &Эксперт
		|	И КИИ_ЭкспертыИИИнструменты.Использовать = ИСТИНА";

	Запрос.УстановитьПараметр("Эксперт", Эксперт);

	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл

		// MCP-инструмент: данные берутся из КИИ_ИнструментыИИ
		Если ЗначениеЗаполнено(Выборка.MCP) Тогда
			Если Не ЗначениеЗаполнено(Выборка.Инструмент) Тогда
				Продолжить; // MCP указан, но инструмент не выбран
			КонецЕсли;

			Инструмент = Новый Структура;
			Инструмент.Вставить("Имя", Выборка.Имя);
			Инструмент.Вставить("Описание", Выборка.Описание);
			Инструмент.Вставить("Параметры", Выборка.ПараметрыJSON);
			Инструмент.Вставить("MCPСервер", Выборка.MCP);
			Инструмент.Вставить("ИнструментСсылка", Выборка.Инструмент);

			Результат.Добавить(Инструмент);

		// Локальный инструмент: данные могли быть в старых колонках (обратная совместимость)
		Иначе
			// Для обратной совместимости -- если указано старое поле Имя напрямую.
			// Если старые колонки (Имя, Описание) были заменены на новые (MCP, Инструмент),
			// локальные инструменты здесь не появятся.
			// Это ожидаемое поведение: локальные инструменты перенесены в отдельный механизм.
			Продолжить;
		КонецЕсли;

	КонецЦикла;

	Возврат Результат;

КонецФункции

