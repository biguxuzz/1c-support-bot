Процедура СформироватьТелоGigaChat(Параметры, СтруктураПромпта, ТелоЗапроса)

	// GigaChat использует OpenAI-совместимый формат
	СформироватьТелоOpenAI(Параметры, СтруктураПромпта, ТелоЗапроса);

