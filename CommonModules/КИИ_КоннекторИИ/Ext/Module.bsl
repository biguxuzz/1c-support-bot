#Область ToolCallingOpenAI

// Формирует массив tools в формате OpenAI
//
Функция СформироватьИнструментыOpenAI(Инструменты)

	МассивTools = Новый Массив;

	Для Каждого Инструмент Из Инструменты Цикл

		Если Не ПроверитьИмяИнструмента(Инструмент.Имя) Тогда
			Продолжить;
		КонецЕсли;

		ToolDef = Новый Структура;
		ToolDef.Вставить("type", "function");

		FunctionDef = Новый Структура;
		FunctionDef.Вставить("name", Инструмент.Имя);
		FunctionDef.Вставить("description", Инструмент.Описание);

		// Параметры: валидация JSON Schema
		Если Инструмент.Свойство("Параметры") Тогда
			Попытка
				Если ТипЗнч(Инструмент.Параметры) = Тип("Строка") Тогда
					SchemaJSON = ОбщегоНазначения.JSONВЗначение(Инструмент.Параметры, , Ложь);
				Иначе
					SchemaJSON = Инструмент.Параметры;
				КонецЕсли;
				FunctionDef.Вставить("parameters", SchemaJSON);
			Исключение
				FunctionDef.Вставить("parameters", Новый Структура("type", "object"));
			КонецПопытки;
		Иначе
			FunctionDef.Вставить("parameters", Новый Структура("type", "object"));
		КонецЕсли;

		ToolDef.Вставить("function", FunctionDef);
		МассивTools.Добавить(ToolDef);

	КонецЦикла;

	Возврат МассивTools;

КонецФункции

// Добавляет инструменты в тело запроса OpenAI
//
Процедура ДобавитьИнструментыВТелоЗапросаOpenAI(ТелоЗапроса, ИнструментыДляЗапроса)

	Если ИнструментыДляЗапроса <> Неопределено
		И ИнструментыДляЗапроса.Количество() > 0 Тогда
		ТелоЗапроса.Вставить("tools", ИнструментыДляЗапроса);
		ТелоЗапроса.Вставить("tool_choice", "auto");
	КонецЕсли;

КонецПроцедуры

// Извлекает tool_calls из ответа OpenAI
//
Функция ИзвлечьВызовыИнструментовOpenAI(ОтветJSON)

	Результат = Новый Массив;

	Если Не ОтветJSON.Свойство("choices") Тогда
		Возврат Результат;
	КонецЕсли;

	Выборка = ОтветJSON.choices[0];

	Если Не Выборка.Свойство("message") Тогда
		Возврат Результат;
	КонецЕсли;

	Сообщение = Выборка.message;

	Если Не Сообщение.Свойство("tool_calls") Тогда
		Возврат Результат;
	КонецЕсли;

	Для Каждого ToolCall Из Сообщение.tool_calls Цикл

		Вызов = Новый Структура;
		Вызов.Вставить("Идентификатор", ToolCall.id);
		Вызов.Вставить("Имя", ToolCall.function.name);

		// Парсинг arguments (JSON-строка)
		Попытка
			Вызов.Вставить("Аргументы",
				ОбщегоНазначения.JSONВЗначение(
					ToolCall.function.arguments, , Ложь));
		Исключение
			Вызов.Вставить("Аргументы", Новый Структура);
		КонецПопытки;

		Результат.Добавить(Вызов);

	КонецЦикла;

	Возврат Результат;

КонецФункции

// Формирует сообщения с результатами инструментов для OpenAI (role: tool)
//
Функция СформироватьСообщенияРезультатовИнструментовOpenAI(
	ToolCallsИзОтвета, РезультатыВызовов)

	МассивСообщений = Новый Массив;

	// Сообщение assistant с tool_calls
	СообщениеAssistant = Новый Структура;
	СообщениеAssistant.Вставить("role", "assistant");
	СообщениеAssistant.Вставить("content", Неопределено);

	МассивToolCalls = Новый Массив;
	Для Каждого ToolCall Из ToolCallsИзОтвета Цикл
		ToolCallСтруктура = Новый Структура;
		ToolCallСтруктура.Вставить("id", ToolCall.Идентификатор);
		ToolCallСтруктура.Вставить("type", "function");

		FunctionCall = Новый Структура;
		FunctionCall.Вставить("name", ToolCall.Имя);
		FunctionCall.Вставить("arguments",
			ОбщегоНазначения.ЗначениеВJSON(ToolCall.Аргументы));
		ToolCallСтруктура.Вставить("function", FunctionCall);

		МассивToolCalls.Добавить(ToolCallСтруктура);
	КонецЦикла;

	СообщениеAssistant.Вставить("tool_calls", МассивToolCalls);
	МассивСообщений.Добавить(СообщениеAssistant);

	// Сообщения tool с результатами
	Для Индекс = 0 По РезультатыВызовов.ВГраница() Цикл
		РезультатВызова = РезультатыВызовов[Индекс];
		ToolCall = ToolCallsИзОтвета[Индекс];

		СообщениеTool = Новый Структура;
		СообщениеTool.Вставить("role", "tool");
		СообщениеTool.Вставить("tool_call_id", ToolCall.Идентификатор);

		Если РезультатВызова.Успешно Тогда
			ТекстРезультата = ОбщегоНазначения.ЗначениеВJSON(
				РезультатВызова.Данные);
		Иначе
			ТекстРезультата = СтрШаблон("Ошибка: %1",
				РезультатВызова.ТекстОшибки);
		КонецЕсли;

		СообщениеTool.Вставить("content", ТекстРезультата);
		МассивСообщений.Добавить(СообщениеTool);
	КонецЦикла;

	Возврат МассивСообщений;

КонецФункции

// Извлекает tool_calls из ответа Yandex (аналогично OpenAI)
//
Функция ИзвлечьВызовыИнструментовYandex(ОтветJSON)

	// Yandex использует формат, аналогичный OpenAI
	РезультатYandex = ПолучитьРезультатYandex(ОтветJSON);
	Если РезультатYandex = Неопределено Тогда
		Возврат Новый Массив;
	КонецЕсли;

	Если Не РезультатYandex.Свойство("alternatives")
		Или Не ЭтоМассив(РезультатYandex.alternatives)
		Или РезультатYandex.alternatives.Количество() = 0 Тогда
		Возврат Новый Массив;
	КонецЕсли;

	Вариант = РезультатYandex.alternatives[0];
	Если Не ЭтоСтруктура(Вариант) Тогда
		Возврат Новый Массив;
	КонецЕсли;

	Если Не Вариант.Свойство("message")
		Или Не ЭтоСтруктура(Вариант.message) Тогда
		Возврат Новый Массив;
	КонецЕсли;

	Сообщение = Вариант.message;
	Если Не Сообщение.Свойство("tool_calls") Тогда
		Возврат Новый Массив;
	КонецЕсли;

	Результат = Новый Массив;
	Для Каждого ToolCall Из Сообщение.tool_calls Цикл

		Вызов = Новый Структура;
		Вызов.Вставить("Идентификатор", ?(ToolCall.Свойство("id"), ToolCall.id, ""));
		Вызов.Вставить("Имя", ToolCall.function.name);

		Попытка
			Вызов.Вставить("Аргументы",
				ОбщегоНазначения.JSONВЗначение(
					ToolCall.function.arguments, , Ложь));
		Исключение
			Вызов.Вставить("Аргументы", Новый Структура);
		КонецПопытки;

		Результат.Добавить(Вызов);

	КонецЦикла;

	Возврат Результат;

КонецФункции

