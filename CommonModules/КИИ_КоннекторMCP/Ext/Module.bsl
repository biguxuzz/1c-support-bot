// Подключается к MCP-серверу, получает список инструментов (tools/list)
// и записывает их в справочник КИИ_ИнструментыИИ
//
// Параметры:
//  MCPСервер - СправочникСсылка.КИИ_MCPСерверы - MCP-сервер для обновления
//
// Возвращаемое значение:
//  Структура:
//    * Успешно - Булево
//    * КоличествоИнструментов - Число - количество загруженных инструментов
//    * ТекстОшибки - Строка - описание ошибки (при Успешно = Ложь)
//
Функция ПодключитьИОбновитьИнструменты(MCPСервер) Экспорт

	Результат = Новый Структура;
	Результат.Вставить("Успешно", Ложь);
	Результат.Вставить("КоличествоИнструментов", 0);
	Результат.Вставить("ТекстОшибки", "");

	Попытка
		ПараметрыСервера = ПараметрыMCPСервера(MCPСервер);
		КлючAPI = ПолучитьКлючAPI(MCPСервер);

		// Выполнить запрос tools/list
		РезультатСписка = ВыполнитьToolsList(ПараметрыСервера, КлючAPI);

		Если Не РезультатСписка.Успешно Тогда
			Результат.ТекстОшибки = РезультатСписка.ТекстОшибки;
			ЗаписьЖурналаРегистрации(
				НСтр("ru = 'КИИ.MCP.ОбновлениеИнструментов'", ОбщегоНазначения.КодОсновногоЯзыка()),
				УровеньЖурналаРегистрации.Ошибка,
				Метаданные.Справочники.КИИ_MCPСерверы,
				MCPСервер,
				РезультатСписка.ТекстОшибки);
			Возврат Результат;
		КонецЕсли;

		// Записать/обновить инструменты в справочник
		КоличествоИнструментов = ЗаписатьИнструментыВСправочник(
			MCPСервер, РезультатСписка.Инструменты);

		Результат.Успешно = Истина;
		Результат.КоличествоИнструментов = КоличествоИнструментов;

		ЗаписьЖурналаРегистрации(
			НСтр("ru = 'КИИ.MCP.ОбновлениеИнструментов'", ОбщегоНазначения.КодОсновногоЯзыка()),
			УровеньЖурналаРегистрации.Информация,
			Метаданные.Справочники.КИИ_MCPСерверы,
			MCPСервер,
			СтрШаблон(НСтр("ru = 'Обновлено %1 инструментов'"), КоличествоИнструментов));

	Исключение
		Результат.ТекстОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		ЗаписьЖурналаРегистрации(
			НСтр("ru = 'КИИ.MCP.ОбновлениеИнструментов'", ОбщегоНазначения.КодОсновногоЯзыка()),
			УровеньЖурналаРегистрации.Ошибка,
			Метаданные.Справочники.КИИ_MCPСерверы,
			MCPСервер,
			Результат.ТекстОшибки);
	КонецПопытки;

	Возврат Результат;

КонецФункции

// Вызывает инструмент на MCP-сервере через tools/call
//
// Параметры:
//  MCPСервер - СправочникСсылка.КИИ_MCPСерверы - MCP-сервер
//  ИмяИнструмента - Строка - имя вызываемого инструмента
//  АргументыJSON - Строка - JSON-строка с аргументами инструмента
//
// Возвращаемое значение:
//  Структура:
//    * Успешно - Булево
//    * ТекстРезультата - Строка - текстовый результат вызова
//    * ТекстОшибки - Строка - описание ошибки (при Успешно = Ложь)
//
Функция ВызватьИнструмент(MCPСервер, ИмяИнструмента, АргументыJSON) Экспорт

	Результат = Новый Структура;
	Результат.Вставить("Успешно", Ложь);
	Результат.Вставить("ТекстРезультата", "");
	Результат.Вставить("ТекстОшибки", "");

	Попытка
		ПараметрыСервера = ПараметрыMCPСервера(MCPСервер);
		КлючAPI = ПолучитьКлючAPI(MCPСервер);

		// Выполнить запрос tools/call
		РезультатВызова = ВыполнитьToolsCall(
			ПараметрыСервера, КлючAPI, ИмяИнструмента, АргументыJSON);

		Если Не РезультатВызова.Успешно Тогда
			Результат.ТекстОшибки = РезультатВызова.ТекстОшибки;

			ЗаписьЖурналаРегистрации(
				НСтр("ru = 'КИИ.MCP.ВызовИнструмента'", ОбщегоНазначения.КодОсновногоЯзыка()),
				УровеньЖурналаРегистрации.Ошибка,
				Метаданные.Справочники.КИИ_MCPСерверы,
				MCPСервер,
				СтрШаблон(НСтр("ru = 'Ошибка вызова инструмента %1: %2'"),
					ИмяИнструмента, РезультатВызова.ТекстОшибки));

			Возврат Результат;
		КонецЕсли;

		Результат.Успешно = Истина;
		Результат.ТекстРезультата = РезультатВызова.ТекстРезультата;

	Исключение
		Результат.ТекстОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
	КонецПопытки;

	Возврат Результат;

КонецФункции

