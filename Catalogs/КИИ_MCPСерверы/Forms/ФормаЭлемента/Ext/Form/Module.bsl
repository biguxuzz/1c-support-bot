#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	Если ЗначениеЗаполнено(Объект.Ссылка) Тогда
		ЗагрузитьAPIКлюч();
	КонецЕсли;

	//// Настройка таблицы инструментов (только чтение)
	//Инструменты = Новый ТаблицаЗначений;
	//Инструменты.Колонки.Добавить("Наименование", Новый ОписаниеТипов("Строка"));
	//Инструменты.Колонки.Добавить("Описание", Новый ОписаниеТипов("Строка"));

	// Загрузить существующие инструменты
	ЗагрузитьИнструменты();

	НастроитьЭлементыФормы();

КонецПроцедуры

&НаСервере
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)

	СохранитьAPIКлюч(ТекущийОбъект.Ссылка);
	НастроитьЭлементыФормы();

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ОбновитьИнструменты(Команда)

	Состояние = НСтр("ru = 'Обновление...'");
	Результат = ОбновитьИнструментыНаСервере();

	Если Результат.Успешно Тогда
		Состояние = СтрШаблон(
			НСтр("ru = 'Загружено инструментов: %1'"),
			Результат.КоличествоИнструментов);
	Иначе
		Состояние = СтрШаблон(
			НСтр("ru = 'Ошибка: %1'"),
			Результат.ТекстОшибки);
		ПоказатьПредупреждение(, Результат.ТекстОшибки, ,
			НСтр("ru = 'Ошибка обновления инструментов'"));
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ПроверитьПодключение(Команда)

	Состояние = НСтр("ru = 'Проверка подключения...'");
	Результат = ПроверитьПодключениеНаСервере();

	Если Результат.Успешно Тогда
		Состояние = СтрШаблон(
			НСтр("ru = 'Подключение успешно. Инструментов: %1'"),
			Результат.КоличествоИнструментов);
	Иначе
		Состояние = СтрШаблон(НСтр("ru = 'Ошибка: %1'"), Результат.ТекстОшибки);
		ПоказатьПредупреждение(, Результат.ТекстОшибки, ,
			НСтр("ru = 'Ошибка подключения'"));
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область РаботаСAPIКлючом

&НаСервере
Процедура ЗагрузитьAPIКлюч()

	Попытка
		КлючХранения = "MCP_" + Строка(Объект.Ссылка.УникальныйИдентификатор());
		КлючAPI = ОбщегоНазначения.ПрочитатьДанныеИзБезопасногоХранилища(
			Объект.Ссылка, КлючХранения);

		Если КлючAPI = Неопределено Тогда
			КлючAPI = "";
		КонецЕсли;

	Исключение
		КлючAPI = "";

		ЗаписьЖурналаРегистрации(
			НСтр("ru = 'КИИ.MCP.ЗагрузкаКлюча'", ОбщегоНазначения.КодОсновногоЯзыка()),
			УровеньЖурналаРегистрации.Ошибка,
			Метаданные.Справочники.КИИ_MCPСерверы,
			Объект.Ссылка,
			ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
	КонецПопытки;

КонецПроцедуры

&НаСервере
Процедура СохранитьAPIКлюч(Ссылка)

	КлючХранения = "MCP_" + Строка(Ссылка.УникальныйИдентификатор());

	Если ЗначениеЗаполнено(КлючAPI) Тогда
		Попытка
			ОбщегоНазначения.ЗаписатьДанныеВБезопасноеХранилище(
				Ссылка, КлючAPI, КлючХранения);
		Исключение
			ЗаписьЖурналаРегистрации(
				НСтр("ru = 'КИИ.MCP.СохранениеКлюча'", ОбщегоНазначения.КодОсновногоЯзыка()),
				УровеньЖурналаРегистрации.Ошибка,
				Метаданные.Справочники.КИИ_MCPСерверы,
				Ссылка,
				ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		КонецПопытки;
	Иначе
		Попытка
			ОбщегоНазначения.УдалитьДанныеИзБезопасногоХранилища(
				Ссылка, КлючХранения);
		Исключение
			ЗаписьЖурналаРегистрации(
				НСтр("ru = 'КИИ.MCP.УдалениеКлюча'", ОбщегоНазначения.КодОсновногоЯзыка()),
				УровеньЖурналаРегистрации.Ошибка,
				Метаданные.Справочники.КИИ_MCPСерверы,
				Ссылка,
				ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		КонецПопытки;
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область ОбновлениеИнструментов

&НаСервере
Функция ОбновитьИнструментыНаСервере()

	Если Не ЗначениеЗаполнено(Объект.Ссылка) Тогда
		Результат = Новый Структура("Успешно, КоличествоИнструментов, ТекстОшибки",
			Ложь, 0,
			НСтр("ru = 'Сначала запишите элемент справочника'"));
		Возврат Результат;
	КонецЕсли;

	Результат = КИИ_КоннекторИИ.ПодключитьИОбновитьИнструменты(Объект.Ссылка);

	Если Результат.Успешно Тогда
		ЗагрузитьИнструменты();
	КонецЕсли;

	Возврат Результат;

КонецФункции

&НаСервере
Процедура ЗагрузитьИнструменты()

	Инструменты.Очистить();

	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	КИИ_ИнструментыИИ.Наименование КАК Наименование,
		|	КИИ_ИнструментыИИ.Описание КАК Описание
		|ИЗ
		|	Справочник.КИИ_ИнструментыИИ КАК КИИ_ИнструментыИИ
		|ГДЕ
		|	КИИ_ИнструментыИИ.Владелец = &Владелец
		|
		|УПОРЯДОЧИТЬ ПО
		|	КИИ_ИнструментыИИ.Наименование";
	Запрос.УстановитьПараметр("Владелец", Объект.Ссылка);

	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		НоваяСтрока = Инструменты.Добавить();
		НоваяСтрока.Наименование = Выборка.Наименование;
		НоваяСтрока.Описание = Выборка.Описание;
	КонецЦикла;

КонецПроцедуры

#КонецОбласти

#Область ПроверкаПодключения

&НаСервере
Функция ПроверитьПодключениеНаСервере()

	Если Не ЗначениеЗаполнено(Объект.Ссылка) Тогда
		Возврат Новый Структура("Успешно, КоличествоИнструментов, ТекстОшибки",
			Ложь, 0,
			НСтр("ru = 'Сначала запишите элемент справочника'"));
	КонецЕсли;

	// Пробуем получить список инструментов как проверку подключения
	Результат = КИИ_КоннекторИИ.ПодключитьИОбновитьИнструменты(Объект.Ссылка);
	Возврат Результат;

КонецФункции

#КонецОбласти

