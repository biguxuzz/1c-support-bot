#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда
#Область ПрограммныйИнтерфейс

// Обновляет список инструментов MCP-сервера
//
// Параметры:
//  MCPСервер - СправочникСсылка.КИИ_MCPСерверы
//
// Возвращаемое значение:
//  Структура:
//    * Успешно - Булево
//    * КоличествоИнструментов - Число
//    * ТекстОшибки - Строка
//
Процедура ОбновитьИнструменты(MCPСервер) Экспорт

	Результат = КИИ_КоннекторИИ.ПодключитьИОбновитьИнструменты(MCPСервер);

	Если Результат.Успешно Тогда
		ЗаписьЖурналаРегистрации(
			НСтр("ru = 'КИИ.MCP.ОбновлениеИнструментов'", ОбщегоНазначения.КодОсновногоЯзыка()),
			УровеньЖурналаРегистрации.Информация,
			Метаданные.Справочники.КИИ_MCPСерверы,
			MCPСервер,
			СтрШаблон(НСтр("ru = 'Обновлено %1 инструментов'"), Результат.КоличествоИнструментов));
	Иначе
		ЗаписьЖурналаРегистрации(
			НСтр("ru = 'КИИ.MCP.ОбновлениеИнструментов'", ОбщегоНазначения.КодОсновногоЯзыка()),
			УровеньЖурналаРегистрации.Ошибка,
			Метаданные.Справочники.КИИ_MCPСерверы,
			MCPСервер,
			Результат.ТекстОшибки);
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции


#КонецОбласти

#КонецЕсли
